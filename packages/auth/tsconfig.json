{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "preserveSymlinks": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023"
  },
  "include": ["src/**/*.ts"]
}
